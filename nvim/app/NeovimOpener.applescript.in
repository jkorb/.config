on run

  set innerAppPath to POSIX path of (path to resource "__INNER_APP_BUNDLE__")
  tell application innerAppPath to activate

end run

on reopen

  set innerAppPath to POSIX path of (path to resource "__INNER_APP_BUNDLE__")
  tell application innerAppPath to activate

end reopen

on open theItems

  set innerAppPath to POSIX path of (path to resource "__INNER_APP_BUNDLE__")
  tell application innerAppPath to activate

  set homePath to POSIX path of (path to home folder)
  set socketPath to homePath & ".cache/nvim/nvim-neovim-app.sock"

  repeat 20 times
    try
      do shell script "test -S " & quoted form of socketPath
      exit repeat
    on error
      delay 0.1
    end try
  end repeat

  set fileArgs to ""
  repeat with anItem in theItems
    set filePath to POSIX path of anItem
    set fileArgs to fileArgs & " " & quoted form of filePath
  end repeat

  set launchCmd to "/opt/homebrew/bin/nvim --server " & quoted form of socketPath & " --remote "

  do shell script launchCmd & fileArgs

end open
