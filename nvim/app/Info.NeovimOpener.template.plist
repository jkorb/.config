<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>CFBundleName</key>
    <string>__APP_NAME__</string>

    <key>CFBundleDisplayName</key>
    <string>__APP_NAME__</string>

    <key>CFBundleIdentifier</key>
    <string>__APP_ID__</string>

    <!-- AppleScript droplet (has `on open theItems`) -->
    <key>CFBundleExecutable</key>
    <string>droplet</string>

    <key>CFBundlePackageType</key>
    <string>APPL</string>

    <key>CFBundleVersion</key>
    <string>1.0</string>

    <key>CFBundleShortVersionString</key>
    <string>1.0</string>

    <key>CFBundleIconFile</key>
    <string>__APP_ICON__</string>

    <key>NSAppleScriptEnabled</key>
    <true/>

    <!-- Hide opener from Dock / Cmd-Tab -->
    <key>LSUIElement</key>
    <true/>

    <!-- Document types Neovim should handle via this opener -->
    <key>CFBundleDocumentTypes</key>
    <array>
        <!-- Any file (fallback) -->
        <dict>
            <key>CFBundleTypeName</key>
            <string>Any File</string>
            <key>LSItemContentTypes</key>
            <array>
                <string>public.data</string>
            </array>
            <key>CFBundleTypeRole</key>
            <string>Editor</string>
            <key>LSHandlerRank</key>
            <string>Alternate</string>
        </dict>

        <!-- Generic text -->
        <dict>
            <key>CFBundleTypeName</key>
            <string>Plain Text</string>
            <key>LSItemContentTypes</key>
            <array>
                <string>public.plain-text</string>
                <string>public.text</string>
            </array>
            <key>CFBundleTypeExtensions</key>
            <array>
                <string>txt</string>
            </array>
            <key>CFBundleTypeRole</key>
            <string>Editor</string>
            <key>LSHandlerRank</key>
            <string>Default</string>
        </dict>

        <!-- Source code / scripts -->
        <dict>
            <key>CFBundleTypeName</key>
            <string>Source Code</string>
            <key>LSItemContentTypes</key>
            <array>
                <string>public.source-code</string>
                <string>public.script</string>
            </array>
            <key>CFBundleTypeExtensions</key>
            <array>
                <string>c</string>
                <string>h</string>
                <string>cc</string>
                <string>cpp</string>
                <string>hpp</string>
                <string>go</string>
                <string>rs</string>
                <string>py</string>
                <string>js</string>
                <string>ts</string>
                <string>jsx</string>
                <string>tsx</string>
                <string>json</string>
                <string>toml</string>
                <string>yaml</string>
                <string>yml</string>
                <string>lua</string>
                <string>sh</string>
                <string>bash</string>
                <string>zsh</string>
                <string>fish</string>
            </array>
            <key>CFBundleTypeRole</key>
            <string>Editor</string>
            <key>LSHandlerRank</key>
            <string>Default</string>
        </dict>

        <!-- Markdown -->
        <dict>
            <key>CFBundleTypeName</key>
            <string>Markdown</string>
            <key>LSItemContentTypes</key>
            <array>
                <string>public.markdown</string>
                <string>net.daringfireball.markdown</string>
            </array>
            <key>CFBundleTypeExtensions</key>
            <array>
                <string>md</string>
            </array>
            <key>CFBundleTypeRole</key>
            <string>Editor</string>
            <key>LSHandlerRank</key>
            <string>Default</string>
        </dict>

        <!-- LaTeX -->
        <dict>
            <key>CFBundleTypeName</key>
            <string>LaTeX</string>
            <key>LSItemContentTypes</key>
            <array>
                <string>public.tex</string>
                <string>public.latex</string>
            </array>
            <key>CFBundleTypeExtensions</key>
            <array>
                <string>tex</string>
                <string>bib</string>
                <string>cls</string>
                <string>sty</string>
                <string>bst</string>
            </array>
            <key>CFBundleTypeRole</key>
            <string>Editor</string>
            <key>LSHandlerRank</key>
            <string>Default</string>
        </dict>

        <!-- AppleScript -->
        <dict>
            <key>CFBundleTypeName</key>
            <string>AppleScript</string>
            <key>LSItemContentTypes</key>
            <array>
                <string>com.apple.applescript.text</string>
                <string>com.apple.applescript.script</string>
                <string>com.apple.applescript.script-bundle</string>
            </array>
            <key>CFBundleTypeExtensions</key>
            <array>
                <string>applescript</string>
                <string>scpt</string>
                <string>scptd</string>
            </array>
            <key>CFBundleTypeRole</key>
            <string>Editor</string>
            <key>LSHandlerRank</key>
            <string>Default</string>
        </dict>
    </array>
</dict>
</plist>
