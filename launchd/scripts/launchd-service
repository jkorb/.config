#!/bin/zsh
set -euo pipefail

SERVICES_DIR="${XDG_CONFIG_HOME:-$HOME/.config}/launchd/services"
LABEL_PREFIX="com.jkorbmacher."

usage() {
  echo "usage: ${0:t} <enable|disable> <service-name>" >&2
  exit 2
}

cmd="${1:-}"
name="${2:-}"

if [[ -z "$cmd" || -z "$name" ]]; then
  usage
fi

case "$cmd" in
  enable|disable) ;;
  *) usage ;;
esac

if [[ "$name" == /* ]]; then
  plist="$name"
elif [[ "$name" == *.plist ]]; then
  plist="$SERVICES_DIR/$name"
else
  if [[ "$name" == *.* ]]; then
    label="$name"
  else
    label="${LABEL_PREFIX}${name}"
  fi
  plist="$SERVICES_DIR/${label}.plist"
fi

if [[ ! -f "$plist" ]]; then
  echo "error: missing plist: $plist" >&2
  exit 1
fi

domain="gui/${UID}"

if [[ "$cmd" == "enable" ]]; then
  launchctl bootstrap "$domain" "$plist"
else
  launchctl bootout "$domain" "$plist"
fi
