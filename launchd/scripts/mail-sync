#!/usr/bin/python3
import os
import socket
import subprocess
import sys
from pathlib import Path

MB_SYNC = "/opt/homebrew/bin/mbsync"
MU = "/opt/homebrew/bin/mu"
PGRP = "/usr/bin/pgrep"
MAIL_NOTIFY = str(Path(__file__).resolve().parent / "mail-notify")
DEBUG = "--debug" in sys.argv


def has_internet():
    try:
        with socket.create_connection(("1.1.1.1", 53), timeout=2):
            return True
    except OSError:
        return False


def davmail_running():
    result = subprocess.run(
        [PGRP, "-f", "[dD]avmail"],
        stdout=subprocess.DEVNULL,
        stderr=subprocess.DEVNULL,
        check=False,
    )
    return result.returncode == 0


def run_cmd(args):
    stderr = None if DEBUG else subprocess.DEVNULL
    stdout = None if DEBUG else subprocess.DEVNULL
    result = subprocess.run(
        args,
        stdout=stdout,
        stderr=stderr,
        check=False,
    )
    return result.returncode


def muhome_arg():
    xdg_cache = os.environ.get("XDG_CACHE_DIR")
    if not xdg_cache:
        raise RuntimeError("XDG_CACHE_DIR is not set")
    muhome = str(Path(xdg_cache) / "mu")
    return ["--muhome", muhome]


def main():
    if not has_internet():
        return 0
    if not davmail_running():
        return 0

    run_cmd([MB_SYNC, "-a"])
    run_cmd([MU, "-q", "index"] + muhome_arg())
    notify_cmd = [MAIL_NOTIFY]
    if DEBUG:
        notify_cmd.append("--debug")
    run_cmd(notify_cmd)
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
