#!/bin/zsh
set -euo pipefail

if [[ $# -lt 2 ]]; then
  echo "usage: ${0:t} <file> <line>" >&2
  exit 2
fi

file="$1"
line="$2"
state_dir="${XDG_STATE_HOME:-$HOME/.local/state}/nvim"
server_map="$state_dir/servers"

sock=""
best_len=0
if [[ -r "$server_map" ]]; then
  while IFS=$'\t' read -r map_sock map_cwd; do
    [[ -z "$map_sock" || -z "$map_cwd" ]] && continue
    case "$file" in
      "$map_cwd"/*|"$map_cwd")
        if (( ${#map_cwd} > best_len )); then
          best_len=${#map_cwd}
          sock="$map_sock"
        fi
        ;;
    esac
  done < "$server_map"
fi
if [[ -z "$sock" ]]; then
  sock="$(ls -t "$state_dir"/nvim-*.sock 2>/dev/null | head -n1 || true)"
fi
if [[ -z "$sock" ]]; then
  echo "error: no nvim server socket found (checked $server_file)" >&2
  exit 1
fi

nvr --servername "$sock" --remote-silent +"${line}" "$file"
