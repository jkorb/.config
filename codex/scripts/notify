#!/usr/bin/env python3
import json
import os
import subprocess
import sys

payload = sys.argv[1] if len(sys.argv) > 1 else sys.stdin.read()
data = json.loads(payload)
cwd = data.get("cwd", "")
project = os.path.basename(cwd) if cwd else ""
message = f"Turn completed: {project}" if project else "Turn completed"
xdc_config_home = os.environ.get("XDG_CONFIG_HOME", "")
group_id = f"codex.turn-completed.{project}" if project else "codex.turn-completed"

subprocess.run(
    [
        "/opt/homebrew/bin/terminal-notifier",
        "-title",
        "✨ Codex",
        "-message",
        message,
        "-group",
        group_id,
        "-contentImage",
        os.path.join(xdc_config_home, "codex", "assets", "logo.png"),
        "-activate",
        "com.jkorbmacher.tmux",
    ],
    stdout=subprocess.DEVNULL,
    stderr=subprocess.DEVNULL,
    check=False,
)
